<?xml version="1.0" ?>
<robot name="car_disk">
  <material name="ColorChassi">
    <color rgba="0.7 0.3 0.2 1.0"/>
  </material>
  <material name="ColorWheel">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <link name="world"/>
  <link name="empty_link_x"/>
  <link name="disk">
   <inertial>
     <mass value="1"/>
     <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.07" iyz="0" izz="0.02"/>
   </inertial>
   <visual>
     <origin rpy="0 0 0" xyz="0 0 0.1"/>
     <geometry>
       <!-- <box size="0.5 0.3 0.2"/> -->
       <cylinder length="0.2" radius="0.2"/>
     </geometry>
      <material name="ColorChassi"/>
   </visual>
   <collision>
     <origin rpy="0 0 0" xyz="0 0 0.1"/>
     <geometry>
       <cylinder length="0.2" radius="0.2"/>
     </geometry>
      <material name="ColorChassi"/>
   </collision>
  </link>

  <joint name="joint_translation_x" type="prismatic">
    <origin xyz="-0.0 -0.0 0.0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="world"/>
    <child link="empty_link_x"/>
    <limit effort="1" lower="-1.5" upper="1.5" velocity="1"/>
  </joint>
  <joint name="joint_translation_y" type="prismatic">
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="empty_link_x"/>
    <child link="disk"/>
    <limit effort="1" lower="-1.5" upper="1.5" velocity="1"/>
  </joint>

</robot>
