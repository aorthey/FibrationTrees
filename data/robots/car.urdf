<?xml version="1.0" ?>
<robot name="car">
  <material name="ColorChassi">
    <color rgba="0.7 0.3 0.2 1.0"/>
  </material>
  <material name="ColorWheel">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <link name="world"/>
  <link name="empty_link_x"/>
  <link name="empty_link_y"/>

  <link name="chassi">
   <inertial>
     <mass value="1"/>
     <inertia ixx="0.0566666666667" ixy="0" ixz="0" iyy="0.0741666666667" iyz="0" izz="0.0241666666667"/>
   </inertial>
   <visual>
     <origin rpy="0 0 0" xyz="0 0 0.1"/>
     <geometry>
       <box size="0.5 0.3 0.2"/>
     </geometry>
      <material name="ColorChassi"/>
   </visual>
   <collision>
     <origin rpy="0 0 0" xyz="0 0 0.1"/>
     <geometry>
       <box size="0.5 0.3 0.2"/>
     </geometry>
      <material name="ColorChassi"/>
   </collision>
  </link>

  <link name="frontspoiler">
   <inertial>
     <mass value="1"/>
     <inertia ixx="0.0189583333333" ixy="0" ixz="0" iyy="0.0189583333333" iyz="0" izz="0.015625"/>
   </inertial>
   <visual>
     <origin rpy="0 0 0" xyz="0.2 0 0.1"/>
     <geometry>
       <cylinder length="0.2" radius="0.15"/>
     </geometry>
     <material name="ColorChassi"/>
   </visual>
   <collision>
     <origin rpy="0 0 0" xyz="0.4 0 0.1"/>
     <geometry>
       <cylinder length="0.2" radius="0.15"/>
     </geometry>
     <material name="ColorChassi"/>
   </collision>
  </link>

  <joint name="joint_translation_x" type="prismatic">
    <origin xyz="-0.0 -0.0 0.0" rpy="0 0 3.14"/>
    <axis xyz="1 0 0"/>
    <parent link="world"/>
    <child link="empty_link_x"/>
    <limit effort="1" lower="-1.5" upper="1.5" velocity="1"/>
  </joint>
  <joint name="joint_translation_y" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="empty_link_x"/>
    <child link="empty_link_y"/>
    <limit effort="1" lower="-1.5" upper="1.5" velocity="1"/>
  </joint>
  <joint name="joint_rotation_yaw" type="continuous">
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <parent link="empty_link_y"/>
    <child link="chassi"/>
  </joint>

   <link name="wheel1">
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.0118666666667" ixy="0" ixz="0" iyy="0.00936666666667" iyz="0" izz="0.00416666666667"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.08"/>
      </geometry>
      <material name="ColorWheel"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.08"/>
      </geometry>
      <material name="ColorWheel"/>
    </collision>
   </link>

   <link name="wheel2">
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.0118666666667" ixy="0" ixz="0" iyy="0.00936666666667" iyz="0" izz="0.00416666666667"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.08"/>
      </geometry>
      <material name="ColorWheel"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.08"/>
      </geometry>
      <material name="ColorWheel"/>
    </collision>
   </link>

   <link name="wheel3">
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.0118666666667" ixy="0" ixz="0" iyy="0.00936666666667" iyz="0" izz="0.00416666666667"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.08"/>
      </geometry>
      <material name="ColorWheel"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.08"/>
      </geometry>
      <material name="ColorWheel"/>
    </collision>
   </link>

   <link name="wheel4">
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.0118666666667" ixy="0" ixz="0" iyy="0.00936666666667" iyz="0" izz="0.00416666666667"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.08"/>
      </geometry>
      <material name="ColorWheel"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.08"/>
      </geometry>
      <material name="ColorWheel"/>
    </collision>
   </link>

  <joint name="joint_chassi_wheel1" type="fixed">
    <origin rpy="1.57 0 0" xyz="+0.2 +0.2 0"/>
    <parent link="chassi"/>
    <child link="wheel1"/>
  </joint>

  <joint name="joint_chassi_wheel2" type="fixed">
    <origin rpy="1.57 0 0" xyz="+0.2 -0.2 0"/>
    <parent link="chassi"/>
    <child link="wheel2"/>
  </joint>

  <joint name="joint_chassi_wheel3" type="fixed">
    <origin rpy="1.57 0 0" xyz="-0.2 +0.2 0"/>
    <parent link="chassi"/>
    <child link="wheel3"/>
  </joint>

  <joint name="joint_chassi_wheel4" type="fixed">
    <origin rpy="1.57 0 0" xyz="-0.2 -0.2 0"/>
    <parent link="chassi"/>
    <child link="wheel4"/>
  </joint>

  <joint name="joint_chassi_frontspoiler" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="chassi"/>
    <child link="frontspoiler"/>
  </joint>

</robot>
