<?xml version="1.0" ?>
<robot name="kuka_lwr">
  <!-- Colors -->
  <material name="Grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="Orange">
    <color rgba="1.0 0.423529411765 0.0392156862745 1.0"/>
  </material>
  <material name="Blue">
    <color rgba="0.5 0.7 1.0 1.0"/>      
  </material>
  <material name="Endeffector">
    <color rgba="0.9 0.9 0.9 1.0"/>      
  </material>

  <!-- SE2 Links -->
  <link name="world"/>
  <link name="empty_link_x"/>
  <link name="base_link_robot">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000833333333333" ixy="0" ixz="0" iyy="0.000833333333333" iyz="0" izz="0.000833333333333"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.25" length="0.1"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.25" length="0.1"/>
      </geometry>
      <material name="Grey"/>
    </collision>
  </link>
  <joint name="joint_translation_x" type="prismatic">
    <origin xyz="-0.0 -0.0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="world"/>
    <child link="empty_link_x"/>
    <limit effort="1" lower="-1.5" upper="1.5" velocity="1"/>
  </joint>
  <joint name="joint_translation_y" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="empty_link_x"/>
    <child link="base_link_robot"/>
    <limit effort="1" lower="-1.5" upper="1.5" velocity="1"/>
  </joint>
</robot>

